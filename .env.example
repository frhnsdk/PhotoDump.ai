# ── PhotoDump — Environment Configuration ───────────────────────────────────
# Copy this file to .env and edit the values.
#   cp .env.example .env

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8000

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=photodump
DB_USER=photodump
DB_PASS=change_this_db_password

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret_in_production

# ── GPU Face Recognition Service ─────────────────────────────────────────────
# OPTION A: GPU on a SEPARATE server (multi-server setup)
#   GPU_SERVICE_URL=http://192.168.0.106:5050
#
# OPTION B: GPU on the SAME machine (use docker-compose-full.yml)
#   GPU_SERVICE_URL=http://gpu-service:5050
#
# OPTION C: No GPU / face search disabled (leave empty)
#   GPU_SERVICE_URL=
GPU_SERVICE_URL=

# ── GPU Service Settings (only needed on GPU server) ─────────────────────────
GPU_SERVICE_PORT=5050
DEEPFACE_MODEL=Facenet512
DEEPFACE_DETECTOR=retinaface
SIMILARITY_THRESHOLD=0.35
